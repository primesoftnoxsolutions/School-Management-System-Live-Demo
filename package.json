{
  "name": "school-management-system",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "Backend",
    "Frontend"
  ],
  "scripts": {
    "dev:backend": "npm --workspace school-erp-backend run dev",
    "dev:frontend": "npm --workspace school-erp-frontend run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm --workspace school-erp-frontend run build",
    "start": "npm --workspace school-erp-backend run start",
    "start:prod": "npm run build && npm --workspace school-erp-backend run start"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
