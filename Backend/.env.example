# Copy to .env and fill in values before going live.
# Never commit real secrets.

NODE_ENV=production
PORT=5000

# Required: MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/school_erp

# Required in production: long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=replace_with_long_random_secret

# Public site URL (used for CORS). Same origin is fine if Express serves the UI.
FRONTEND_URL=https://your-domain.com

# Set to false only if you must run over plain HTTP (login cookies need this).
# Prefer HTTPS in production.
# COOKIE_SECURE=false

# First Super Admin (created only when no admin exists)
SEED_ADMIN_EMAIL=admin@yourschool.com
SEED_ADMIN_PASSWORD=replace_with_strong_password
SEED_ADMIN_NAME=Super Admin

# Optional: first Finance Manager
# SEED_FINANCE_EMAIL=
# SEED_FINANCE_PASSWORD=
# SEED_FINANCE_NAME=Finance Manager
